<% if model.errors.any? %>
  <div id="error_explanation">
    <%# ↓↓↓ このh2タグの中身を書き換える ↓↓↓ %>
    <h2>
      <%= model.errors.count %>件のエラーが発生したため、<%= model.class.model_name.human %>は保存されませんでした。
    </h2>
    <ul>
      <% model.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>