<%# --- ここからデバッグ情報 --- %>
<div style="background-color: #ffc; padding: 1em; border: 1px solid #ccc;">
  <h3>デバッグ情報</h3>
  <p>@reservation.start_date: <%= @reservation.start_date.inspect %></p>
  <p>@reservation.end_date: <%= @reservation.end_date.inspect %></p>
  <p>計算前のdays: <%= (@reservation.end_date - @reservation.start_date).inspect %></p>
  <p>計算後のdays (.to_i): <%= (@reservation.end_date - @reservation.start_date).to_i.inspect %></p>
  <p>@reservation.people_count: <%= @reservation.people_count.inspect %></p>
  <p>@room.price: <%= @room.price.inspect %></p>
</div>
<%# --- ここまでデバッグ情報 --- %>

<h1>予約内容の確認</h1>

<% 
  days = (@reservation.end_date - @reservation.start_date).to_i
  total_price = days * @reservation.people_count.to_i * @room.price.to_i
%>

<p><strong>施設名:</strong> <%= @room.name %></p>
<p><strong>チェックイン日:</strong> <%= @reservation.start_date.strftime("%Y/%m/%d") %></p>
<p><strong>チェックアウト日:</strong> <%= @reservation.end_date.strftime("%Y/%m/%d") %></p>
<p><strong>人数:</strong> <%= @reservation.people_count %> 人</p>
<p><strong>宿泊日数:</strong> <%= days %> 泊</p>
<p><strong>合計金額:</strong> <%= total_price.to_s(:delimited) %> 円</p>

<hr>

<%# このフォームが、最終的な予約作成(create)アクションにデータを送る %>
<%= form_with(model: [@room, @reservation], local: true) do |f| %>
  <%= f.hidden_field :start_date, value: @reservation.start_date %>
  <%= f.hidden_field :end_date, value: @reservation.end_date %>
  <%= f.hidden_field :people_count, value: @reservation.people_count %>
  <%= f.submit "この内容で予約を確定する" %>
<% end %>

<br>
<%= link_to "施設詳細に戻る", room_path(@room) %>