<h1>予約編集</h1>

<%= form_with(model: @reservation, local: true) do |form| %>
  <% if @reservation.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@reservation.errors.count, "件のエラー") %>があります:</h2>
      <ul>
        <% @reservation.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :user_id, 'ユーザー' %><br>
    <%= form.collection_select :user_id, @users, :id, :name, { prompt: '選択してください' }, { required: true } %>
  </div>

  <div class="field">
    <%= form.label :room_id, '部屋' %><br>
    <%= form.collection_select :room_id, @rooms, :id, :name, { prompt: '選択してください' }, { required: true } %>
  </div>

  <div class="field">
    <%= form.label :start_date, '開始日' %><br>
    <%= form.date_field :start_date, required: true, class: 'form-control' %>
  </div>

  <div class="field">
    <%= form.label :end_date, '終了日' %><br>
    <%= form.date_field :end_date, required: true, class: 'form-control' %>
  </div>

  <div class="field">
    <%= form.label :people_count, '人数' %><br>
    <%= form.number_field :people_count, min: 1, required: true, class: 'form-control' %>
  </div>

  <div class="actions mt-3">
    <%= form.submit '更新する', class: 'btn btn-primary' %>
  </div>
<% end %>

<%= link_to '一覧に戻る', reservations_path, class: 'btn btn-link mt-2' %>
