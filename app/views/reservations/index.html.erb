<!-- app/views/reservations/index.html.erb -->
<h1>予約一覧</h1>

<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% if @reservations.any? %>
  <table>
    <thead>
      <tr>
        <th>ユーザー</th>
        <th>部屋</th>
        <th>チェックイン</th>
        <th>チェックアウト</th>
        <th colspan="2">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @reservations.each do |reservation| %>
        <tr>
          <td><%= reservation.user&.name %></td>
          <td><%= reservation.room&.name %></td>
          <td><%= reservation.start_date&.strftime('%Y/%m/%d') %></td>
          <td><%= reservation.end_date&.strftime('%Y/%m/%d') %></td>
          <td><%= link_to '編集', edit_reservation_path(reservation) %></td>
          <td>
            <%= link_to '削除',
                        reservation_path(reservation),
                        method: :delete,
                        data: { confirm: '本当に削除しますか？' } %>
            <!-- Turbo使用時は下記に置換：
            data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }
            -->
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>予約はまだありません。</p>
<% end %>

<div style="margin-top: 1rem;">
  <%= link_to '新規予約作成', new_reservation_path %>
</div>
