<h1>あなたの予約一覧</h1>

<% if @reservations.any? %>
  <table>
    <thead>
      <tr>
        <th>施設名</th>
        <th>チェックイン</th>
        <th>チェックアウト</th>
        <th>人数</th>
        <th>合計料金</th>
      </tr>
    </thead>

    <tbody>
      <% @reservations.each do |reservation| %>
        <tr>
          <td><%= link_to reservation.room.name, room_path(reservation.room) %></td>
          <td><%= reservation.start_date.strftime("%Y/%m/%d") %></td>
          <td><%= reservation.end_date.strftime("%Y/%m/%d") %></td>
          <td><%= reservation.people_count %> 人</td>
          <td>
            <%# 料金計算: (チェックアウト日 - チェックイン日) * 人数 * 施設の料金 %>
            <%= ((reservation.end_date - reservation.start_date).to_i * reservation.people_count * reservation.room.price).to_s(:delimited) %> 円
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>まだ予約はありません。</p>
<% end %>