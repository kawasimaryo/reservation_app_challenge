<h1>施設検索</h1>

<%= form_with(url: search_rooms_path, method: :get, local: true) do |f| %>
  <div class="field">
    <%= f.label :area, "エリア検索" %>
    <%= f.text_field :area, value: @area, placeholder: "例：東京" %>
  </div>

  <div class="field">
    <%= f.label :keyword, "フリーワード検索" %>
    <%= f.text_field :keyword, value: @keyword, placeholder: "例：綺麗な景色" %>
  </div>

  <div class="actions">
    <%= f.submit "検索" %>
  </div>
<% end %>

<hr>

<% if defined?(@total) %>
  <p>検索結果: 全<%= @total %>件</p>
<% end %>

<% if @rooms.present? %>
  <table>
    <thead>
      <tr>
        <th>施設名</th>
        <th>住所</th>
        <th>施設詳細</th>
        <th>料金 (/日)</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @rooms.each do |room| %>
        <tr>
          <td><%= link_to room.name, room_path(room) %></td>
          <td><%= room.address %></td>
          <td><%= room.description %></td>
          <td><%= "¥#{number_with_delimiter(room.price.to_i)}" %></td>
          <td><%= link_to "詳細", room_path(room) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% elsif @area.present? || @keyword.present? %>
  <p>該当する施設はありませんでした。</p>
<% end %>
