<p><%= image_tag(@room.image.presence || 'default-image-4e0ac6b8d01335b5b22fe6586af13644ae51dddb6aeabf35b9174e80f13cd09d.png', size: "300x300") %></p>

<h1><%= @room.name %></h1>

<p>
  <strong>施設詳細:</strong>
  <%= @room.description %>
</p>

<p>
  <strong>料金（/日）:</strong>
  <%= number_to_currency(
        # price_cents があれば優先、なければ price を数字だけ抽出
        (@room.respond_to?(:price_cents) && @room.price_cents.present? ?
           @room.price_cents :
           @room.price.to_s.gsub(/[^\d]/, '').to_i
        ),
        unit: "¥",
        precision: 0,
        round_mode: :default   # 念のため明示（初期化子を入れていても冪等）
      ) %>
</p>

<p>
  <strong>住所:</strong>
  <%= @room.address %>
</p>

<hr>

<h2>この施設を予約する</h2>

<%= form_with(url: new_room_reservation_path(@room), method: :get, local: true) do |f| %>
  <%= render 'shared/error_messages', model: @reservation %>

  <div class="field">
    <%= f.label :start_date, "チェックイン日" %><br />
    <%= f.date_field :start_date %>
  </div>

  <div class="field">
    <%= f.label :end_date, "チェックアウト日" %><br />
    <%= f.date_field :end_date %>
  </div>

  <div class="field">
    <%= f.label :people_count, "人数" %><br />
    <%= f.number_field :people_count %>
  </div>

  <div class="actions">
    <%= f.submit "予約内容の確認へ" %>
  </div>
<% end %>

<br>

<% if @room.user == current_user %>
  <hr>
  <%= link_to '施設情報を編集する', edit_room_path(@room) %> |
  <%= link_to '施設を削除する', room_path(@room), method: :delete, data: { confirm: '本当に削除しますか？' } %>
<% end %>

<%= link_to '一覧に戻る', rooms_path %>
