<h1>予約一覧</h1>

<% if @reservations.any? %>
  <table>
    <thead>
      <tr>
        <th>施設画像</th>
        <th>施設名</th>
        <th>紹介文</th>
        <th>合計料金</th>
        <th>チェックイン</th>
        <th>チェックアウト</th>
        <th>予約確定日時</th>
      </tr>
    </thead>
    <tbody>
      <% @reservations.each do |reservation| %>
        <tr>
          <td>
            <%= image_tag(
                  (reservation.room.image.attached? ? reservation.room.image : "default_room.png"),
                  alt: reservation.room.name, width: 100, height: 100
                ) %>
          </td>
          <td><%= link_to reservation.room.name, room_path(reservation.room) %></td>
          <td><%= reservation.room.description %></td>
          <td>¥<%= number_with_delimiter(reservation.total_price) %></td>
          <td><%= reservation.start_date.strftime("%Y/%m/%d") %></td>
          <td><%= reservation.end_date.strftime("%Y/%m/%d") %></td>
          <td><%= reservation.created_at.strftime("%Y/%m/%d %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>予約はまだありません。</p>
<% end %>
